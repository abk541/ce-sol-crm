# Copy to server/.env on the VPS. PostgreSQL is private to the VPS. Create a
# dedicated app_runtime login and replace this example password out of band;
# never commit the real value.
DATABASE_URL=postgresql://app_runtime:replace-me@127.0.0.1:5433/ce_crm
HOST=127.0.0.1
PORT=3001
TRUST_PROXY=true
LOG_LEVEL=info

# Exact browser origins, comma-separated. Wildcards are deliberately rejected.
ALLOWED_ORIGINS=https://crm.cesolutionplus.com,https://www.crm.cesolutionplus.com,https://abk541.github.io

# Private directory owned by the unprivileged API service account.
ATTACHMENTS_DIR=/var/lib/ce-crm/attachments
MAX_UPLOAD_BYTES=26214400

# Optional server-side integration secret. It is never returned to the browser.
SAM_GOV_API_KEY=
SAM_GOV_TIMEOUT_MS=20000
SAM_GOV_MAX_RESPONSE_BYTES=5242880

SESSION_TTL_SECONDS=86400
LOGIN_RATE_LIMIT_MAX=8
LOGIN_RATE_LIMIT_WINDOW=1 minute
